# =============================================================================
# darkit/slog — Makefile
# =============================================================================
.PHONY: all build vet test lint fmt cover release clean help

# Go parameters
GOCMD    = go
GOBUILD  = $(GOCMD) build
GOTEST   = $(GOCMD) test
GOVET    = $(GOCMD) vet
GOFMT    = $(GOCMD) fmt
GOMOD    = $(GOCMD) mod
BIN_DIR  = bin
LDFLAGS  = -s -w

# =============================================================================
## all: Default — build + vet + test
# =============================================================================
all: build vet test

# =============================================================================
## build: Compile all packages
# =============================================================================
build:
	$(GOBUILD) -v ./...

# =============================================================================
## build-install: Build and install binary to $(BIN_DIR)
# =============================================================================
build-install:
	@mkdir -p $(BIN_DIR)
	$(GOBUILD) -ldflags "$(LDFLAGS)" -o $(BIN_DIR)/slog ./...

# =============================================================================
## vet: Run go vet
# =============================================================================
vet:
	$(GOVET) ./...

# =============================================================================
## test: Run all tests
# =============================================================================
test:
	$(GOTEST) -count=1 ./...

# =============================================================================
## test-race: Run all tests with race detector
# =============================================================================
test-race:
	$(GOTEST) -race -count=1 ./...

# =============================================================================
## test-verbose: Run all tests with verbose output
# =============================================================================
test-verbose:
	$(GOTEST) -v -count=1 ./...

# =============================================================================
## test-short: Run only short tests
# =============================================================================
test-short:
	$(GOTEST) -short -count=1 ./...

# =============================================================================
## test-bench: Run benchmarks
# =============================================================================
test-bench:
	$(GOTEST) -bench=. -benchmem -count=1 ./...

# =============================================================================
## test-coverage: Run tests and generate coverage report
# =============================================================================
test-coverage:
	$(GOTEST) -race -covermode atomic -coverprofile=coverage.out ./...
	$(GOCMD) tool cover -func=coverage.out
	@echo
	@echo "HTML coverage report: coverage.html"
	$(GOCMD) tool cover -html=coverage.out -o coverage.html

# =============================================================================
## lint: Run golangci-lint
# =============================================================================
lint:
	golangci-lint run ./...

# =============================================================================
## lint-fix: Run golangci-lint with auto-fix
# =============================================================================
lint-fix:
	golangci-lint run --fix ./...

# =============================================================================
## fmt: Run gofmt + goimports
# =============================================================================
fmt:
	$(GOFMT) ./...
	@command -v goimports >/dev/null 2>&1 && goimports -local github.com/darkit/slog -w . || true

# =============================================================================
## tidy: Tidy and verify module dependencies
# =============================================================================
tidy:
	$(GOMOD) tidy
	$(GOMOD) verify

# =============================================================================
## clean: Remove build artifacts and coverage files
# =============================================================================
clean:
	rm -rf $(BIN_DIR) coverage.out coverage.html
	find . -name "*.test" -delete -o -name "*.prof" -delete

# =============================================================================
## release-dry: Dry-run goreleaser
# =============================================================================
release-dry:
	goreleaser release --snapshot --clean

# =============================================================================
## help: Print this help message
# =============================================================================
help:
	@echo "Usage: make [target]"
	@echo ""
	@echo "Targets:"
	@sed -n 's/^##//p' $(MAKEFILE_LIST) | column -t -s ':' | sed -e 's/^/ /'
